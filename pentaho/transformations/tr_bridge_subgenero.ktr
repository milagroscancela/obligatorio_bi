    <connection>obligatorio_bi</connection>
    <sql>SELECT DISTINCT
    SUBSTRING_INDEX(SUBSTRING_INDEX(SUBSTRING_INDEX(url, '/', -1), '.', 1), '-', 1) AS goodreads_id,
    origen_csv,
    CASE WHEN origen_csv = origen_csv THEN true END AS es_primario
FROM Staging_Libros
WHERE url IS NOT NULL
AND origen_csv IS NOT NULL</sql>
    <limit>0</limit>
    <lookup/>
    <execute_each_row>N</execute_each_row>
    <variables_active>N</variables_active>
